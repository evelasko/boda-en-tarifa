# =============================================================================
# Boda en Tarifa — Cloud Functions Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Firebase Functions v2 loads .env files automatically from this directory.
# NEVER commit the actual .env file — only this template.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudinary
# -----------------------------------------------------------------------------
# Used for server-side image operations (signed uploads, transformations, admin)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# -----------------------------------------------------------------------------
# Deep Linking
# -----------------------------------------------------------------------------
# Domain for constructing Magic Link deep links sent to guests
DEEP_LINK_DOMAIN=boda-en-tarifa.com