# Firebase Configuration
# Get these values from your Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Note: authDomain, projectId, storageBucket, and messagingSenderId are hardcoded in firebase.ts
# If you need to change these, update them in src/lib/firebase.ts

# Apple Sign In Configuration (for Firebase Console)
# These values are configured in Firebase Console > Authentication > Sign-in method > Apple
# You'll need to provide these in the Firebase Console:
# - Service ID: com.bodaentarifa.app.service
# - Apple Team ID: Your 10-character Team ID from Apple Developer
# - Key ID: The 10-character Key ID from your private key
# - Private Key: Contents of your .p8 file from Apple Developer
