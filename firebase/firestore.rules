rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // guests/{uid}
    match /guests/{uid} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['email', 'uid', 'side', 'relationToGrooms', 'profileClaimed', 'createdAt']);
      allow delete: if false;
    }

    // feed_posts/{postId}
    match /feed_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isHidden'])
        && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if false;
    }

    // notices/{noticeId}
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // seating/{guestUid}
    match /seating/{guestUid} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // time_gated_content/{contentId}
    match /time_gated_content/{contentId} {
      allow read: if isAuthenticated()
        && resource.data.unlockAt <= request.time;
      allow write: if false;
    }
  }
}
