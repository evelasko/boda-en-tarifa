{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "iOS Simulator",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/app",
      "args": [
        "--dart-define-from-file=.env"
      ],
      "deviceId": "iPhone"
    },
    {
      "name": "iOS Simulator (Debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/app",
      "flutterMode": "debug",
      "args": [
        "--dart-define-from-file=.env"
      ],
      "deviceId": "iPhone"
    },
    {
      "name": "iOS Simulator (Profile)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/app",
      "flutterMode": "profile",
      "args": [
        "--dart-define-from-file=.env"
      ],
      "deviceId": "iPhone"
    }
  ]
}
