# =============================================================================
# Boda en Tarifa — Flutter App Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# The app uses the envied package (or --dart-define) to inject these at build time.
# NEVER commit the actual .env file — only this template.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — Android
# -----------------------------------------------------------------------------
# Firebase API key for the Android app
# Found in: Firebase Console > Project Settings > General > Your apps > Android
FIREBASE_ANDROID_API_KEY=your_android_api_key_here

# Firebase app ID for Android
FIREBASE_APP_ID_ANDROID=your_android_app_id_here

# -----------------------------------------------------------------------------
# Firebase — iOS
# -----------------------------------------------------------------------------
# Firebase API key for the iOS app
# Found in: Firebase Console > Project Settings > General > Your apps > iOS
FIREBASE_IOS_API_KEY=your_ios_api_key_here

# Firebase app ID for iOS
FIREBASE_APP_ID_IOS=your_ios_app_id_here

# -----------------------------------------------------------------------------
# Firebase — Shared
# -----------------------------------------------------------------------------
# Firebase project identifier (e.g., boda-en-tarifa)
FIREBASE_PROJECT_ID=boda-en-tarifa

# FCM sender ID (numeric)
# Found in: Firebase Console > Project Settings > Cloud Messaging
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here

# -----------------------------------------------------------------------------
# Cloudinary
# -----------------------------------------------------------------------------
# Cloudinary cloud name for image uploads and URL construction
# Found in: Cloudinary Console > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# -----------------------------------------------------------------------------
# Mapbox
# -----------------------------------------------------------------------------
# Mapbox public access token for map rendering and offline tile downloads
# Found in: Mapbox Account > Access Tokens
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# -----------------------------------------------------------------------------
# Deep Linking
# -----------------------------------------------------------------------------
# Domain used for Universal Links (iOS) and App Links (Android)
DEEP_LINK_DOMAIN=boda-en-tarifa.com